<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<StackPane prefHeight="600.0" prefWidth="800.0" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" fx:controller="JavaFXexample.StudentController">
   <children>
      <VBox maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity" prefHeight="400.0" prefWidth="600.0" styleClass="card">
         <children>
            <TableView fx:id="studentTable" prefHeight="200.0" prefWidth="200.0">
              <columns>
                <TableColumn fx:id="idColumn" prefWidth="75.0" text="ID" />
                <TableColumn fx:id="nameColumn" prefWidth="75.0" text="Name" />
                  <TableColumn fx:id="gpaColumn" prefWidth="75.0" text="GPA" />
                  <TableColumn fx:id="departmentColumn" prefWidth="75.0" text="Department" />
              </columns>
               <columnResizePolicy>
                  <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
               </columnResizePolicy>
            </TableView>
            <HBox alignment="CENTER" prefHeight="100.0" prefWidth="200.0" spacing="10.0">
               <children>
                  <TextField fx:id="idField" promptText="ID" />
                  <TextField fx:id="nameField" promptText="Name" />
                  <TextField fx:id="gpaField" promptText="GPA" />
                  <TextField fx:id="departmentField" promptText="Department" />
               </children>
            </HBox>
            <HBox alignment="TOP_CENTER" prefHeight="100.0" prefWidth="200.0" spacing="30.0">
               <children>
                  <Button mnemonicParsing="false" onAction="#addStudent" text="Add Student" />
                  <Button mnemonicParsing="false" onAction="#deleteStudent" text="Delete Student" />
                  <Button mnemonicParsing="false" onAction="#updateStudent" text="Update Student" />
               </children>
            </HBox>
            <Button mnemonicParsing="false" onAction="#returnDashboard" text="Return" />
         </children>
      </VBox>
   </children>
</StackPane>
